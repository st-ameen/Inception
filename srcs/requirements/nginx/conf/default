server {
	listen 443 ssl;
	listen [::]:443 ssl;

	server_name ${DOMAIN_NAME};

	ssl_protocols       TLSv1.2 TLSv1.3;
	ssl_certificate     /etc/ssl/certs/ssl-cert-snakeoil.pem;
	ssl_certificate_key /etc/ssl/private/ssl-cert-snakeoil.key;

	root  /var/www/html;
	index index.html;

	location / {
		try_files $uri $uri/ =404;
	}
}